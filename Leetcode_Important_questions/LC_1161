//By level order traversal
/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int maxLevelSum(TreeNode root) {
        if(root==null)return 0;
        if(root.left==null && root.right==null)return 1;
        Queue<TreeNode> q = new LinkedList<>();
        q.add(root);
        int maxSum = Integer.MIN_VALUE;
        int minLevel = 1;
        int currLevel = 0;
        while(!q.isEmpty()){
            int currSum = 0;
            int size = q.size();
            currLevel++;
            for(int i = 0;i<size;i++){
                TreeNode curr = q.remove();
                currSum+=curr.val;
                if(curr.left!=null){
                    q.add(curr.left);
                }
                if(curr.right!=null){
                    q.add(curr.right);
                }
            }
            if(currSum>maxSum){
                maxSum = currSum;
                minLevel = currLevel;
            }    
        }
        return minLevel;
    }
}


//By recursion
class Solution {
    public int maxLevelSum(TreeNode root) {
        // List<Integer> list = new ArrayList<>();
        int list[] = new int[10001];
        int maxSum = root.val, maxInd=1;

        int level = traverse(root, list, 1);

        for(int i=1;i<=level;i++) {
            if(list[i] > maxSum) {
                maxSum = list[i];
                maxInd = i;
            }
        }
        

        return maxInd;
    }

    private int traverse(TreeNode root, int[] list, int level) {
        if(root == null) {
            return level-1;
        }

        list[level] += root.val;



        return Math.max(traverse(root.left, list, level+1), traverse(root.right, list, level+1));
    }
}