class Solution {
    public double angleClock(int hour, int minutes) {
        int hr = hour%12;
        double hrA = hr*30 + (double)minutes/2;
        double mA = minutes*6;
        double ans = Math.abs(hrA-mA);
        if(ans>=180){
            ans -= 360;
        }
        ans = Math.abs(ans);
        return ans;
    }
}