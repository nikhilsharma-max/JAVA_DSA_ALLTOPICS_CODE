class Solution {
    public int numberOfSubstrings(String s) {
        int ans = 0;
        for(int i = 0;i<s.length();i++){
            int freq[] = new int[3];
            for(int j = i;j<s.length();j++){
                freq[s.charAt(i)-'a']++;
                if(isValid(freq))ans++;
            }
        }
        return ans;
    }
    public boolean isValid(int freq[]){
        for(int i = 0;i<3;i++){
            if(freq[i]<1)return false;
        }
        return true;
    }
}