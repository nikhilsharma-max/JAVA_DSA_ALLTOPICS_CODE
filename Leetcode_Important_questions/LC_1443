class Solution {
    public int minTime(int n, int[][] edges, List<Boolean> hasApple) {
        // making adj
        HashMap<Integer,List<Integer>> adj = new HashMap<>();
        for(int i = 0;i<edges.length;i++){
            int u = edges[i][0];
            int v = edges[i][1];
            adj.computeIfAbsent(u, k -> new ArrayList<>()).add(v);
            adj.computeIfAbsent(v, k -> new ArrayList<>()).add(u);
        }
        return dfs(adj,0,-1,hasApple);
    }
    public int dfs(HashMap<Integer,List<Integer>> adj,int curr,int par,List<Boolean> hasApple){
        int time = 0;
        List<Integer> neigh = adj.get(curr);
        if(neigh==null)return 0;
        for(int child:neigh){
            if(child==par)continue;
            int timeFromChild = dfs(adj,child,curr,hasApple);
            if(timeFromChild>0 || hasApple.get(child)){
                time+=(timeFromChild+2);
            }
        }
        return time;
    }
}