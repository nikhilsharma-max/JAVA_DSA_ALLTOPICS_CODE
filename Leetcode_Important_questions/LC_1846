class Solution {
    public int maximumElementAfterDecrementingAndRearranging(int[] arr) {
        Arrays.sort(arr);
        arr[0] = 1;
        int ans = arr[0];
        for(int i = 1;i<arr.length;i++){
            if(Math.abs(arr[i-1]-arr[i])<=1){
                ans = Math.max(ans,arr[i]);
                continue;
            }else{
                arr[i] = arr[i-1]+1;
            }
            ans = Math.max(ans,arr[i]);
        }
        return ans;
    }
}