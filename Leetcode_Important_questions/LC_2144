class Solution {
    public int minimumCost(int[] c) {
        if(c.length==1)return c[0];
        if(c.length==2){
            return (c[0]+c[1]);
        }
        int cost[] = new int[c.length];
        Arrays.sort(c);
        for(int i= 0;i<c.length;i++){
            cost[i] = c[c.length-i-1];
        }
        int minCost = 0;
        for(int i = 0;i<cost.length;i++){
            if((i+1)%3==0)continue;
            minCost+=cost[i];
        }
        return minCost;
    }
}