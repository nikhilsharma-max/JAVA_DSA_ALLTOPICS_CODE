class Solution {

    public TreeNode lowestCommonAncestor(TreeNode root, TreeNode p, TreeNode q) {
        ArrayList<TreeNode> path1 = new ArrayList<>();
        ArrayList<TreeNode> path2 = new ArrayList<>();
        
        pathTo(root, p, path1);
        pathTo(root, q, path2);
        
        TreeNode ans = null;
        int minLen = Math.min(path1.size(), path2.size());
        
        for (int i = 0; i < minLen; i++) {
            if (path1.get(i) != path2.get(i)) {
                ans = path1.get(i - 1);
                break;
            }
        }
        
        if (ans == null) {
            ans = path1.get(minLen - 1);
        }
        
        return ans;
    } 
    
    // Fixed pathTo method
    private boolean pathTo(TreeNode root, TreeNode target, ArrayList<TreeNode> path) {
        if (root == null) return false;
        
        path.add(root);
        
        if (root == target) return true;
        
        // Continue searching in children
        if (pathTo(root.left, target, path) || pathTo(root.right, target, path)) {
            return true;
        }
        
        // Backtrack if not found in this subtree
        path.remove(path.size() - 1);
        return false;
    }
}