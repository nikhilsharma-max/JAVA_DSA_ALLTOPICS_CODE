class Solution {
    public int search(int[] nums, int target) {
        if(nums.length==1){
            if(nums[0]==target)return 0;
            else return -1;
        }
        return modifiedSearch(nums,target,0,nums.length-1);
    }
    
    private int modifiedSearch(int arr[],int target, int left, int right){
        if(left>right){
            return -1;
        }
        int mid = left+(right-left)/2;
        if(arr[mid]==target){
            return mid;
        }
        //if left half is sorted
        if(arr[mid]>=arr[left]){
            //if key is in left half
            if(arr[left]<=target && target <= arr[mid]){
                return modifiedSearch(arr,target,left,mid-1);
            }else{
                return modifiedSearch(arr,target,mid+1,right);
            }
        }else{
            //If right half is sorted

            //if key is present in right half
            if(arr[mid]<=target && target<=arr[right]){
                return modifiedSearch(arr,target,mid+1,right);
            }else{
                return modifiedSearch(arr,target,left,mid-1);
            }
        }
    }
}