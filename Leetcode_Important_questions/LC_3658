class Solution {
    public int gcdOfOddEvenSums(int n) {
        if(n==1)return 1;
            int nOdd = n/2;
            int sumOdd = n*n;
            int sumEven = sumOdd+n;
            return gcd(sumOdd,sumEven);
    }
    public int gcd(int a, int b){
        if(b==0)return a;
        return gcd(b,a%b);
    }
}