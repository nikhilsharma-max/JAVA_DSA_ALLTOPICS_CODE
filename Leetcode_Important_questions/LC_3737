class Solution {
    public int countMajoritySubarrays(int[] nums, int target) {
        int ans = 0;
        for(int i = 0;i<nums.length;i++){
            int freq = 0;
            if(nums[i]==target)freq++;
            for(int j = i;j<nums.length;j++){
                int len = j-i+1;
                if(j!=i && nums[j]==target)freq++;
                if(freq>len/2)ans++;          
            }
        }
        return ans;
    }
}