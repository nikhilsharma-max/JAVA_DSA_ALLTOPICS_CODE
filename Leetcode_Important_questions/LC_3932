class Solution {
    public int countKthRoots(int l, int r, int k) {
        if(k==1)return r-l+1;       
        int count = 0;
        
        for(int i = 0;i<=r;i++){
            long value = 1;
            int j = 0;
            value = (long)Math.pow(i,k);
            if(value<l){
                continue;
            }else if(value>r){
                break;
            }else{
                count++;
            }
        }
        return count;
    }
}