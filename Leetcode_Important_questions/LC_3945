class Solution {
    public int digitFrequencyScore(int n) {
        int arr[] = new int[10];
        int num = n;
        while(num>0){
            int rem = num%10;
            arr[rem]++;
            num/=10;
        }
        int score = 0;
        for(int i =0 ;i<10;i++){
            score+=i*arr[i];
        }
        return score;
    }
}