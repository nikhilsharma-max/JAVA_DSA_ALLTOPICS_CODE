class Solution {
    public int maxDigitRange(int[] nums) {
        Map<Integer,Integer> map = new HashMap<>();
        int maxR = Integer.MIN_VALUE;
        for(int num:nums){
            int digRange = calculateRange(num);
            maxR = Math.max(maxR,digRange);
            map.put(digRange,map.getOrDefault(digRange,0)+num);
        }
        return map.get(maxR);
    }
    public int calculateRange(int n){
        int num = n;
        int min = Integer.MAX_VALUE;
        int max = Integer.MIN_VALUE;
        while(num>0){
            int rem = num%10;
            min = Math.min(rem,min);
            max = Math.max(max,rem);
            num/=10;
        }
        return Math.abs(max-min);
    }
}