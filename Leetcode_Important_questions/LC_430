/*
// Definition for a Node.
class Node {
    public int val;
    public Node prev;
    public Node next;
    public Node child;
};
*/

class Solution {
    public Node flatten(Node head) {
        if(head==null)return head;
        Node temp = head;
        while(temp!=null){
            if(temp==null)return head;
            if(temp.next==null && temp.child!=null){
                temp.next = temp.child;
                temp.child.prev = temp;
                temp.child = null;
            }else if(temp.child!=null){
                Node childTemp = temp.child;
                while(childTemp.next!=null){
                    childTemp = childTemp.next;
                }
                childTemp.next = temp.next;
                temp.next.prev = childTemp;
                temp.next = temp.child;
                temp.child.prev = temp;
                temp.child = null;
            }
            temp = temp.next;
        }
        return head;
    }

}