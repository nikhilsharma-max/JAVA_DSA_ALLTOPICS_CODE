import java.util.*;

class KthLargest {
    // Min-heap (PriorityQueue) to keep track of the k largest elements
    private PriorityQueue<Integer> pq;
    private int k;

    public KthLargest(int k, int[] nums) {
        this.k = k;
        this.pq = new PriorityQueue<>(); // min-heap by default
        
        for (int num : nums) {
            add(num); // reuse add logic to initialize
        }
    }
    
    public int add(int val) {
        pq.offer(val);
        
        // If heap size exceeds k, remove the smallest element
        if (pq.size() > k) {
            pq.poll();
        }
        
        // The smallest element in the min-heap of k elements is the kth largest
        return pq.peek();
    }
}

