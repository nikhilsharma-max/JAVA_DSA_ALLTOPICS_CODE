class StockSpanner {
    public class Pair{
        int price;
        int span;
        public Pair(int price,int span){
            this.price = price;
            this.span = span;
        }
    }
    Stack<Pair> s;
    public StockSpanner() {
        s = new Stack<>();
    }
    
    public int next(int price) {
        int span = 1;
        while(!s.isEmpty() && s.peek().price<=price){
            Pair curr = s.pop();
            span+=curr.span;
        }
        s.push(new Pair(price,span));
        return span;
    }
}

